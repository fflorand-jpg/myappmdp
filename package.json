{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:mobile": "vite build && cap sync",
    "build:cordova": "vite build && node -e \"const fs = require('fs'); if (fs.existsSync('www')) { fs.rmSync('www', {recursive: true}); } fs.cpSync('dist', 'www', {recursive: true}); console.log('Succès : Les fichiers Cordova sont prêts dans le dossier www !');\"",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js www",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfmake": "^0.3.11",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sql.js": "^1.14.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@types/express": "^4.17.21",
